{
  "name": "clinical-ordering-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "preview:ci": "vite preview --host 127.0.0.1 --port 4173",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e:cypress": "npm run build && node ./scripts/run-with-server.mjs preview:ci http://127.0.0.1:4173 cypress:run",
    "cypress:run": "cypress run",
    "test:e2e:cypress:open": "cypress open",
    "test:e2e:selenium": "node ./tests/selenium/clinical-ordering.smoke.mjs",
    "test:perf:lighthouse": "node ./scripts/run-with-server.mjs preview:ci http://127.0.0.1:4173 lighthouse:run",
    "lighthouse:run": "lhci autorun --config=./lighthouserc.json",
    "test:all:ui": "npm run test:unit && npm run test:e2e:cypress"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^6.0.1",
    "cypress": "^15.14.2",
    "jsdom": "^29.1.1",
    "selenium-webdriver": "^4.25.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
